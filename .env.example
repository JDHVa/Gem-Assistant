# ═══════════════════════════════════════════════════════════
#   GEM — Plantilla de configuración
#   1) cp .env.example .env
#   2) Rellena UNA de las dos opciones de credenciales
# ═══════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────┐
# │  OPCIÓN A — Google AI Studio                            │
# │  Key: https://aistudio.google.com/apikey                │
# └─────────────────────────────────────────────────────────┘
USAR_VERTEX=false
GEMINI_API_KEY=AIzaSy_TU_KEY_AQUI
GEMINI_MODELO=gemini-2.5-flash
GEMINI_MODELO_STT=gemini-2.5-flash
TTS_VOZ=Kore

# ┌─────────────────────────────────────────────────────────┐
# │  OPCIÓN B — Vertex AI                                   │
# │  gcloud auth application-default login                  │
# │  gcloud services enable aiplatform.googleapis.com       │
# │  gcloud services enable texttospeech.googleapis.com     │
# └─────────────────────────────────────────────────────────┘
# USAR_VERTEX=true
# VERTEX_PROJECT=mi-proyecto-gcp
# VERTEX_LOCATION=us-central1
# GEMINI_MODELO=gemini-2.0-flash-001
# GEMINI_MODELO_STT=gemini-2.0-flash-001
# TTS_IDIOMA=es-US
# TTS_VOZ_CLOUD=es-US-Neural2-A

# ═══════════════════════════════════════════════════════════
#   VAD — Detección de voz por duración de frase
#   (sin wake word; solo habla y espera)
# ═══════════════════════════════════════════════════════════

# Cuánto ruido cuenta como "voz" (0.0–1.0)
# Sube si se activa solo con ruido ambiente (~0.02–0.05)
# Baja si no te detecta bien (~0.005)
VAD_RMS_UMBRAL=0.012

# Mínimo de voz continua para que se dispare (segundos)
# Sube si se activa con toses/ruidos cortos (~1.5–2.0)
# Baja si frases muy cortas no se detectan (~0.5)
VAD_MIN_FRASE_S=0.8

# Silencio para dar la frase por terminada (segundos)
SILENCE_DURATION_S=1.2

# Pausa post-TTS para no re-activar con la voz del asistente
FALLBACK_COOLDOWN_S=5.0

# ═══════════════════════════════════════════════════════════
#   Servidor
# ═══════════════════════════════════════════════════════════
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8765
